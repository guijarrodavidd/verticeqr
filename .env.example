# Copia este archivo como .env y rellena con tus credenciales reales.
# El archivo .env NO se sube a Git (está en .gitignore).

DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=verticeqr_test

# Token aleatorio fuerte (p.ej. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`).
# Protege el endpoint admin /api/admin/sql. Si no se define, el endpoint queda deshabilitado.
ADMIN_TOKEN=
